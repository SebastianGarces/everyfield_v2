# Database
DATABASE_URL=postgresql://user:password@localhost:5432/everyfield

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage (Tigris / S3-compatible)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_REGION=auto
AWS_BUCKET_NAME=your-bucket-name

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx
EMAIL_FROM=EveryField <notifications@yourdomain.com>

# Sentry error tracking (optional — left unset, Sentry no-ops in local dev)
# Server-side DSN
SENTRY_DSN=
# Client-side DSN (exposed to the browser)
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload (build-time only; leave unset to skip uploads)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
